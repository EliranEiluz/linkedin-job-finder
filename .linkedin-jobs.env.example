# Copy this file to ~/.linkedin-jobs.env and fill in real values.
# Then: chmod 600 ~/.linkedin-jobs.env

# --- Email (Gmail example) ---
# Generate an app password at https://myaccount.google.com/apppasswords
# (regular Gmail password will NOT work — Google blocks it for SMTP).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.address@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_TO=your.address@gmail.com

# Implicit SSL (SMTPS, port 465) vs. STARTTLS (default).
# Port 465 auto-enables SSL; for any other port set SMTP_USE_SSL=1 to force it.
# Required by iCloud, Fastmail, Yahoo (they don't accept STARTTLS).
# SMTP_USE_SSL=1
#
# iCloud:    SMTP_HOST=smtp.mail.me.com  SMTP_PORT=587 (or 465 + SMTP_USE_SSL=1)
#            SMTP_USER must use an app-specific password.
# Fastmail:  SMTP_HOST=smtp.fastmail.com SMTP_PORT=465
# Outlook:   SMTP_HOST=smtp.office365.com SMTP_PORT=587 (STARTTLS)

# --- LLM scoring backend (pick one — first configured wins) ---
# Order tried: claude CLI -> Anthropic SDK -> Gemini -> OpenAI -> OpenRouter -> Ollama.
# Override the auto-resolve via config.json: {"llm_provider": {"name": "..."}}.
# Verify with:  python3 backend/search.py --test-llm

# Anthropic API key (only needed if `claude` CLI isn't installed).
# Get one at https://console.anthropic.com.
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — free tier 1500 RPM. https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# OpenAI / ChatGPT — paid only, no free tier. https://platform.openai.com/api-keys
# Default model gpt-4o-mini: ~$0.15/M input, $0.60/M output.
# OPENAI_API_KEY=sk-...

# OpenRouter — many free model slugs. https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# Ollama runs at http://localhost:11434 by default — no env var needed.
# Override the host or model if you've moved them:
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:32b
